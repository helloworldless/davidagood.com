---
layout: layouts/base.njk
---

{% for post in collections.posts %}
  <article>
    <header>
      <h3>
        {% if post.data.isExternal %}
          <a href="{{ post.data.externalUrl }}">{{ post.data.title }} ↗</a>
        {% else %}
          <a href="{{ post.url }}">{{ post.data.title }}</a>
        {% endif %}
      </h3>
      <small>{{ post.date | readableDate }}</small>
    </header>
    <section>
      <p>{{ post.data.description or (post.content | excerpt) }}</p>
    </section>
  </article>
{% endfor %}
